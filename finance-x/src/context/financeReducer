

export function financeReducer(state, action) {
    switch(action.type) {
case 'ADD_TRANSACTION':
    return [
        ...state,
        action.payload
    ]

case 'DELETE_TRANSACTION':
    return [
      state.filter(transaction => transaction.id !== action.payload.id)
    ]
case 'EDIT_TRANSACTION':
    return 
        state.map(transaction => transaction.id === action.payload.id ? action.payload : transaction)

case 'CLEAR_ALL':
    return []

        default:
            return state
    }
}
